{
  "cors": {
    "enabled": true,
    "origin": "*"
  },
  "metrics": {
    "enabled": true
  },
  "request-id": {
    "enabled": true,
    "headerName": "x-request-id"
  },
  "rate-limiter-redis": {
    "enabled": true,
    "windowMs": 60000,
    "maxRequests": 100,
    "algorithm": "fixed",
    "keyStrategy": "ip"
  },
  "routes": {
    "/users": {
      "plugins": {
        "jwt-auth": {
          "enabled": true,
          "publicPaths": [
            "/users/public",
            "/users/health"
          ]
        },
        "rate-limiter-redis": {
          "enabled": true,
          "maxRequests": 50,
          "algorithm": "sliding"
        }
      }
    },
    "/orders": {
      "plugins": {
        "jwt-auth": {
          "enabled": true
        },
        "cache": {
          "enabled": true,
          "ttl": 30
        },
        "request-log": {
          "enabled": true
        }
      }
    },
    "/products": {
      "plugins": {
        "cache": {
          "enabled": true,
          "ttl": 300
        },
        "compression": {
          "enabled": true
        },
        "rate-limiter-redis": {
          "enabled": true,
          "maxRequests": 200
        }
      }
    }
  }
}
