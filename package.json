{
  "name": "apix-gateway",
  "version": "1.0.0",
  "description": "A modern, fast API Gateway built with Node.js - rate limiting, authentication, caching, analytics",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "apix": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "keywords": [
    "api-gateway",
    "gateway",
    "proxy",
    "rate-limiting",
    "authentication",
    "jwt",
    "oauth",
    "caching",
    "microservices"
  ],
  "author": "Sagar Jadhav",
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.0",
    "http-proxy-middleware": "^3.0.0",
    "redis": "^4.7.0",
    "jsonwebtoken": "^9.0.2",
    "helmet": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "winston": "^3.14.0",
    "joi": "^17.13.0",
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "vitest": "^2.0.0"
  }
}
