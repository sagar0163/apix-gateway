{
  "name": "apix-gateway",
  "version": "1.3.0",
  "description": "A modern, fast API Gateway built with Node.js - rate limiting, authentication, caching, analytics",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "apix": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "version": "node src/cli.js version",
    "release": "node src/cli.js release",
    "release:patch": "node src/cli.js release patch",
    "release:minor": "node src/cli.js release minor",
    "release:major": "node src/cli.js release major",
    "changelog": "node src/cli.js changelog",
    "notes": "node src/cli.js notes",
    "status": "node src/cli.js status"
  },
  "keywords": [
    "api-gateway",
    "gateway",
    "proxy",
    "rate-limiting",
    "authentication",
    "jwt",
    "oauth",
    "caching",
    "microservices"
  ],
  "author": "Sagar Jadhav",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^4.21.0",
    "helmet": "^8.0.0",
    "http-proxy-middleware": "^3.0.0",
    "joi": "^18.1.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.7.0",
    "winston": "^3.14.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "supertest": "^7.2.2",
    "vitest": "^2.0.0"
  }
}
