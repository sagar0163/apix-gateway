# JWT Secret - REQUIRED - Must be at least 32 characters
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars

# Admin credentials - Set these via environment, not defaults
# Format: JSON string like {"admin":{"password":"your-password","role":"admin"}}
ADMIN_USERS=
ADMIN_PASSWORD=
DEVELOPER_PASSWORD=

# API Key
API_KEY=your-api-key-here

# OAuth2
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=

# Rate Limiting
RATE_WINDOW_MS=60000
RATE_MAX_REQUESTS=100

# Request Limits
MAX_BODY_SIZE=1048576
MAX_HEADER_SIZE=8192
REQUEST_TIMEOUT=30000

# Input Validation
BLOCK_SQL_INJECTION=false
PASSWORD_STRENGTH_CHECK=true

# CORS
CORS_ORIGIN=localhost

# Redis (optional - for distributed rate limiting)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
LOG_STRUCTURED=false

# HTTP/2 Support (requires SSL certificates)
HTTP2=false
SSL_KEY_PATH=./ssl/server.key
SSL_CERT_PATH=./ssl/server.crt

# Trust Proxy
TRUST_PROXY=true

# Node Environment
NODE_ENV=development

# SSL Verification (only disable in development!)
DISABLE_SSL_VERIFY=false
